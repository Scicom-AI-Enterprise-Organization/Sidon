# Sidon secrets — copy to .env and fill in. (.env is gitignored.)
# Format: KEY=value, one per line. This file is both shell-sourced
# (`set -a; source .env`) and parsed by runpod/launch_pod.py's stdlib loader,
# so use plain values with no surrounding quotes and no spaces around `=`.

# --- Required ---------------------------------------------------------------
# RunPod REST API key — provisioning/status/terminate via runpod/launch_pod.py.
RUNPOD_API_KEY=

# Hugging Face token — dataset/model downloads and pushes (Scicom-intl/sidon-callcentre).
HF_TOKEN=

# Weights & Biases key — training run logging. Leave blank to disable W&B.
WANDB_API_KEY=

# --- Optional overrides (sensible defaults in code; uncomment to change) -----
# Set to `disabled` to turn off W&B even when WANDB_API_KEY is present.
# WANDB_MODE=online

# RunPod REST base URL (default: https://rest.runpod.io/v1).
# RUNPOD_API_BASE=https://rest.runpod.io/v1

# Pod base image (default: runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404).
# RUNPOD_IMAGE=runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404
